   "id": "cell-09",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 9 — Identify Top 3 Failure Clusters\n",
    "# ============================================================\n",
    "\n",
    "# Base stats (same as CSV version)\n",
    "agg_dict = {\n",
    "    \"mean_score\"  : (\"retrieval_score\", \"mean\"),\n",
    "    \"median_score\": (\"retrieval_score\", \"median\"),\n",
    "    \"std_score\"   : (\"retrieval_score\", \"std\"),\n",
    "    \"miss_count\"  : (\"retrieval_score\", lambda x: (x < MISS_THRESHOLD).sum()),\n",
    "    \"total_count\" : (\"retrieval_score\", \"count\"),\n",
    "}\n",
    "\n",
    "# OTel enrichment: add latency per cluster if available\n",
    "cluster_stats = df.groupby(\"cluster\").agg(\n",
    "    mean_score   =(\"retrieval_score\", \"mean\"),\n",
    "    median_score =(\"retrieval_score\", \"median\"),\n",
    "    std_score    =(\"retrieval_score\", \"std\"),\n",
    "    miss_count   =(\"retrieval_score\", lambda x: (x < MISS_THRESHOLD).sum()),\n",
    "    total_count  =(\"retrieval_score\", \"count\"),\n",
    ").reset_index()\n",
