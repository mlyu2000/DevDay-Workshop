   "source": [
    "---\n",
    "### Cell 3 — Parse Traces into Analysis Dataframe\n",
    "\n",
    "### Why this step exists\n",
    "\n",
    "Raw Langfuse traces are nested JSON. This cell flattens each trace into a single row with the same schema as the CSV version: `query_text`, `timestamp`, `user_id`, `retrieval_score`, `session_id`. It also extracts OTel-specific enrichment columns — `latency_ms`, `input_tokens`, `output_tokens`, `top_k_scores` — that are not available in the CSV version and enable richer analysis.\n",
    "\n",
    "If the API was unavailable and `USE_CSV_FALLBACK=True`, this cell loads the static CSV instead. After this cell, all downstream steps are identical regardless of data source."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-03",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3 — Parse Traces → Flat Dataframe\n",
    "# ============================================================\n",
    "import pandas as pd\n",
    "import json\n",
    "\n",
    "def _extract_retrieval_score(trace):\n",
    "    \"\"\"\n",
    "    Extract top-1 retrieval score from a Langfuse trace.\n",
    "    Langfuse stores scores as a list of {name, value} dicts.\n",
    "    The RAG chain logs the score under the name 'retrieval_score'.\n",
    "    Falls back to searching observations (spans) for the score.\n",
    "    \"\"\"\n",
    "    # 1. Check trace-level scores\n",
    "    for score in trace.get(\"scores\", []):\n",
    "        if score.get(\"name\") == \"retrieval_score\":\n",
    "            return float(score[\"value\"])\n",
    "\n",
    "    # 2. Check observations (spans) for retrieval span output\n",
    "    for obs in trace.get(\"observations\", []):\n",
    "        if obs.get(\"name\", \"\").lower() in (\"retrieval\", \"qdrant_retrieval\", \"similarity_search\"):\n",
    "            output = obs.get(\"output\", {})\n",
    "            if isinstance(output, dict):\n",
    "                scores = output.get(\"scores\", [])\n",
    "                if scores:\n",
    "                    return float(max(scores))\n",
    "\n",
    "    # 3. Fallback: check metadata\n",
    "    meta = trace.get(\"metadata\", {}) or {}\n",
    "    if \"retrieval_score\" in meta:\n",
    "        return float(meta[\"retrieval_score\"])\n",
    "\n",
    "    return None\n",
    "\n",
    "\n",
    "def _extract_latency(trace):\n",
    "    \"\"\"Extract total trace latency in milliseconds.\"\"\"\n",
    "    latency = trace.get(\"latency\")\n",
    "    if latency is not None:\n",
    "        return float(latency)\n",
    "    # Compute from timestamps if latency field absent\n",
    "    start = trace.get(\"timestamp\")\n",
    "    end   = trace.get(\"updatedAt\")\n",
    "    if start and end:\n",
    "        try:\n",
    "            from datetime import datetime\n",
    "            t0 = datetime.fromisoformat(start.replace(\"Z\", \"+00:00\"))\n",
    "            t1 = datetime.fromisoformat(end.replace(\"Z\", \"+00:00\"))\n",
    "            return (t1 - t0).total_seconds() * 1000\n",
    "        except Exception:\n",
    "            pass\n",
    "    return None\n",
    "\n",
    "\n",
    "def _extract_token_counts(trace):\n",
    "    \"\"\"Extract input/output token counts from LLM span.\"\"\"\n",
    "    for obs in trace.get(\"observations\", []):\n",
    "        usage = obs.get(\"usage\", {})\n",
    "        if usage and obs.get(\"type\") == \"GENERATION\":\n",
    "            return (\n",
    "                usage.get(\"input\",  usage.get(\"promptTokens\",     0)),\n",
    "                usage.get(\"output\", usage.get(\"completionTokens\", 0)),\n",
    "            )\n",
    "    return (None, None)\n",
    "\n",
    "\n",
    "def traces_to_dataframe(traces):\n",
    "    \"\"\"Flatten a list of Langfuse trace dicts into a pandas DataFrame.\"\"\"\n",
    "    rows = []\n",
    "    for t in traces:\n",
    "        meta          = t.get(\"metadata\", {}) or {}\n",
    "        input_data    = t.get(\"input\", {})\n",
    "        query_text    = None\n",
    "\n",
    "        # Query text can live in different places depending on chain structure\n",
    "        if isinstance(input_data, str):\n",
    "            query_text = input_data\n",
    "        elif isinstance(input_data, dict):\n",
    "            query_text = (\n",
    "                input_data.get(\"question\")\n",
    "                or input_data.get(\"query\")\n",
    "                or input_data.get(\"input\")\n",
    "                or str(input_data)\n",
    "            )\n",
    "\n",
    "        retrieval_score        = _extract_retrieval_score(t)\n",
    "        latency_ms             = _extract_latency(t)\n",
    "        input_tokens, out_toks = _extract_token_counts(t)\n",
    "\n",
    "        rows.append({\n",
    "            \"trace_id\"       : t.get(\"id\"),\n",
    "            \"query_text\"     : query_text,\n",
    "            \"timestamp\"      : t.get(\"timestamp\"),\n",
    "            \"user_id\"        : t.get(\"userId\") or meta.get(\"user_id\"),\n",
    "            \"session_id\"     : t.get(\"sessionId\") or meta.get(\"session_id\"),\n",
    "            \"retrieval_score\": retrieval_score,\n",
    "            \"latency_ms\"     : latency_ms,\n",
    "            \"input_tokens\"   : input_tokens,\n",
    "            \"output_tokens\"  : out_toks,\n",
    "            \"user_roles\"     : meta.get(\"user_roles\"),\n",
    "            \"model_name\"     : meta.get(\"model_name\"),\n",
    "        })\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "\n",
    "# --- Build dataframe from traces or CSV fallback -----------------\n",
    "if USE_CSV_FALLBACK or not raw_traces:\n",
    "    print(f\"Loading CSV fallback: {CSV_FALLBACK_PATH}\")\n",
    "    df = pd.read_csv(CSV_FALLBACK_PATH, sep=\",\")\n",
    "    df.columns = df.columns.str.strip().str.lower()\n",
    "    df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], utc=True, errors=\"coerce\")\n",
    "    # Add OTel-enrichment columns as NaN for schema consistency\n",
    "    for col in [\"trace_id\", \"latency_ms\", \"input_tokens\", \"output_tokens\",\n",
    "                \"user_roles\", \"model_name\"]:\n",
    "        if col not in df.columns:\n",
    "            df[col] = None\n",
    "    data_source = \"CSV fallback\"\n",
    "else:\n",
    "    df = traces_to_dataframe(raw_traces)\n",
    "    df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], utc=True, errors=\"coerce\")\n",
    "    data_source = \"Langfuse API\"\n",
    "\n",
    "# --- Clean -------------------------------------------------------\n",
    "before = len(df)\n",
    "df = df.dropna(subset=[\"query_text\", \"retrieval_score\"])\n",
    "df[\"query_text\"] = df[\"query_text\"].astype(str).str.strip()\n",
    "df = df[df[\"query_text\"].str.len() > 3].reset_index(drop=True)\n",
    "after = len(df)\n",
    "\n",
    "print(f\"\\u2705 Dataframe built from {data_source}.\")\n",
    "print(f\"   Rows loaded     : {before}\")\n",
    "print(f\"   Rows after clean: {after} ({before - after} dropped)\")\n",
    "print(f\"   Columns         : {list(df.columns)}\")\n",
    "print()\n",
    "print(\"   First 5 rows:\")\n",
    "display(df.head())\n",
    "print()\n",
    "\n",
    "# --- OTel-specific enrichment summary (only if from API) ---------\n",
    "if data_source == \"Langfuse API\":\n",
    "    print(\"   OTel enrichment summary:\")\n",
    "    if df[\"latency_ms\"].notna().any():\n",
    "        print(f\"     Latency (ms)    : mean={df['latency_ms'].mean():.0f}, \"\n",
    "              f\"p95={df['latency_ms'].quantile(0.95):.0f}\")\n",
    "    if df[\"input_tokens\"].notna().any():\n",
    "        print(f\"     Input tokens    : mean={df['input_tokens'].mean():.0f}\")\n",
    "    if df[\"output_tokens\"].notna().any():\n",
    "        print(f\"     Output tokens   : mean={df['output_tokens'].mean():.0f}\")\n",
    "    if df[\"user_roles\"].notna().any():\n",
    "        role_counts = df[\"user_roles\"].value_counts().head(5)\n",
    "        print(f\"     Top user roles  : {role_counts.to_dict()}\")\n",
    "print()\n",
    "print(\"   Retrieval score summary:\")\n",
    "print(df[\"retrieval_score\"].describe().round(4))"
   ]
  },
