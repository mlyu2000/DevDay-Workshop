    "---\n",
    "## 📡 Step 1 — Fetch Traces from Langfuse\n",
    "\n",
    "### Cell 2 — Paginate the Langfuse Traces API\n",
    "\n",
    "### Why this step exists\n",
    "\n",
    "The Langfuse REST API returns traces in pages of up to 100 records. We paginate through the endpoint, collecting traces tagged with `lab2a` until we have 500 records. Each trace is a JSON object containing the root span input (the user query), output (the LLM response), scores (including the retrieval score logged by the RAG chain), and custom metadata (user_id, session_id, user_roles).\n",
    "\n",
    "The `scores` field is populated by the `CallbackHandler` in Lab 2A — specifically the retrieval span's top-1 cosine similarity score that was logged as a named score on the trace."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-02",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 2 — Fetch Traces from Langfuse REST API\n",
    "# ============================================================\n",
    "import requests\n",
    "import base64\n",
    "import time\n",
    "import os\n",
    "\n",
    "def _langfuse_auth_header(public_key, secret_key):\n",
    "    \"\"\"Build Basic Auth header from Langfuse key pair.\"\"\"\n",
    "    token = base64.b64encode(\n",
    "        f\"{public_key}:{secret_key}\".encode()\n",
    "    ).decode()\n",
    "    return {\"Authorization\": f\"Basic {token}\",\n",
    "            \"Content-Type\" : \"application/json\"}\n",
    "\n",
    "\n",
    "def fetch_langfuse_traces(\n",
    "    base_url, public_key, secret_key,\n",
    "    limit=500, page_size=50, tags=None\n",
    "):\n",
    "    \"\"\"\n",
    "    Paginate the Langfuse /api/public/traces endpoint.\n",
    "    Returns a list of raw trace dicts.\n",
    "    \"\"\"\n",
    "    headers  = _langfuse_auth_header(public_key, secret_key)\n",
    "    endpoint = f\"{base_url}/api/public/traces\"\n",
    "    traces   = []\n",
    "    page     = 1\n",
    "\n",
    "    while len(traces) < limit:\n",
    "        params = {\"page\": page, \"limit\": min(page_size, limit - len(traces))}\n",
    "        if tags:\n",
    "            params[\"tags\"] = \",\".join(tags)\n",
    "\n",
    "        resp = requests.get(endpoint, headers=headers, params=params, timeout=30)\n",
    "\n",
    "        if resp.status_code == 401:\n",
    "            raise PermissionError(\n",
    "                \"\\u274c Langfuse authentication failed.\\n\"\n",
    "                \"   Check LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY.\"\n",
    "            )\n",
    "        if resp.status_code == 404:\n",
    "            raise ConnectionError(\n",
    "                f\"\\u274c Langfuse API not found at {endpoint}.\\n\"\n",
    "                f\"   Check LANGFUSE_BASE_URL.\"\n",
    "            )\n",
    "        resp.raise_for_status()\n",
    "\n",
    "        data  = resp.json()\n",
    "        batch = data.get(\"data\", [])\n",
    "        if not batch:\n",
    "            print(f\"   No more traces at page {page}. Stopping.\")\n",
    "            break\n",
    "\n",
    "        traces.extend(batch)\n",
    "        total_available = data.get(\"meta\", {}).get(\"totalItems\", \"?\")\n",
    "        print(f\"   Fetched {len(traces)}/{min(limit, total_available)} traces \"\n",
    "              f\"(page {page})...\", end=\"\\r\")\n",
    "        page += 1\n",
    "        time.sleep(0.1)  # polite rate limiting\n",
    "\n",
    "    return traces[:limit]\n",
    "\n",
    "\n",
    "# --- Execute fetch or fallback -----------------------------------\n",
    "if USE_CSV_FALLBACK:\n",
    "    print(\"\\u26a0\\ufe0f  USE_CSV_FALLBACK=True — skipping API fetch.\")\n",
    "    print(\"   Cell 3 will load from CSV instead.\")\n",
    "    raw_traces = []\n",
    "else:\n",
    "    print(f\"Fetching up to {TRACE_LIMIT} traces from Langfuse...\")\n",
    "    print(f\"   Endpoint : {LANGFUSE_BASE_URL}/api/public/traces\")\n",
    "    print(f\"   Tags     : {TRACE_TAGS}\")\n",
    "    print()\n",
    "    try:\n",
    "        raw_traces = fetch_langfuse_traces(\n",
    "            base_url   = LANGFUSE_BASE_URL,\n",
    "            public_key = LANGFUSE_PUBLIC_KEY,\n",
    "            secret_key = LANGFUSE_SECRET_KEY,\n",
    "            limit      = TRACE_LIMIT,\n",
    "            page_size  = TRACE_PAGE_SIZE,\n",
    "            tags       = TRACE_TAGS,\n",
    "        )\n",
    "        print()\n",
    "        print(f\"\\u2705 Fetched {len(raw_traces)} raw traces from Langfuse.\")\n",
    "        if len(raw_traces) < 100:\n",
    "            print(f\"\\u26a0\\ufe0f  Only {len(raw_traces)} traces found.\")\n",
    "            print(f\"   Tip: Run more Lab 2A queries to populate the trace store,\")\n",
    "            print(f\"   or set USE_CSV_FALLBACK = True to use the static dataset.\")\n",
    "    except Exception as e:\n",
    "        print(f\"\\u274c API fetch failed: {e}\")\n",
    "        print(f\"   Falling back to CSV: {CSV_FALLBACK_PATH}\")\n",
    "        raw_traces = []\n",
    "        USE_CSV_FALLBACK = True\n",
    "\n",
    "# Peek at raw structure\n",
    "if raw_traces:\n",
    "    sample = raw_traces[0]\n",
    "    print()\n",
    "    print(\"   Sample trace keys:\", list(sample.keys()))\n",
    "    print(f\"   Sample trace ID  : {sample.get('id')}\")\n",
    "    print(f\"   Sample timestamp : {sample.get('timestamp')}\")"
   ]
